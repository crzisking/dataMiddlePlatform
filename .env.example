# ===== 应用 =====
APP_NAME=data-middle-platform
APP_ENV=dev
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# ===== PostgreSQL（RAG 向量库 + 中台元数据）=====
PG_HOST=127.0.0.1
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=changeme
PG_DATABASE=data_platform

# ===== SQL Server（业务数据，只读，TextToSQL 用；P5 启用）=====
# 留空则 TextToSQL 相关功能自动跳过（health/mssql 返回 skipped）。填 HOST + DATABASE 才算启用。
MSSQL_HOST=
MSSQL_PORT=1433
MSSQL_USER=
MSSQL_PASSWORD=
MSSQL_DATABASE=
MSSQL_TIMEOUT=30
# TDS 协议版本：SQL Server 2008/2008R2 用 7.0（新版本与老库 TLS 握手会失败）。
# 2012+ 的库可改 7.3/7.4。详见 app/core/config.py 的说明。
MSSQL_TDS_VERSION=7.0

# ===== 任务队列：procrastinate 复用上面的 PostgreSQL，无需额外配置 =====

# ===== MinIO（上传原件对象存储）=====
MINIO_ENDPOINT=192.168.120.198:9000
MINIO_ACCESS_KEY=KUexgN1kwl7FcfSKZuJG
MINIO_SECRET_KEY=请填入真实密钥
MINIO_BUCKET=temp
MINIO_SECURE=false

# ===== LLM：通义千问（DashScope OpenAI 兼容）=====
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_API_KEY=
QWEN_DEFAULT_MODEL=qwen3.7-plus

# ===== LLM：DeepSeek =====
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_API_KEY=
DEEPSEEK_DEFAULT_MODEL=deepseek-v4-pro

# ===== 可暴露给前端的对话模型白名单（逗号分隔）=====
# 从厂商官网/接口查到要用的模型名填这里（厂商 /models 会返回上百个混杂模型，不能全暴露）。
# /meta/models 接口返回的就是这两个列表；模型名→厂商的路由也按此自动建。改了重启生效。
QWEN_MODELS=qwen3.7-max,qwen3.7-plus
DEEPSEEK_MODELS=deepseek-v4-pro

# ===== Embedding（通义 text-embedding-v3）=====
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_DIM=1024

# ===== 重排序 rerank（混合检索后精排，可配开关，默认关）=====
RERANK_ENABLED=false
RERANK_MODEL=gte-rerank-v2

# ===== 上传限制（白名单可配置：逗号分隔扩展名；大小单位 MB）=====
UPLOAD_MAX_MB=100
# 只放能解析出文字的格式；doc/xls 老二进制格式暂不支持解析，故不放
UPLOAD_ALLOWED_EXTS=pdf,docx,xlsx,txt,md

# ===== 文档类型受控词表（逗号分隔）=====
# 上传/筛选下拉的来源（/meta/doc-types 返回）。运维可改，前端自动跟着变。
DOC_TYPES=通用,SOP,工艺,质量,设备手册,制度

# ===== 上线硬化（P8）=====
# 正式环境务必把 APP_DEBUG 设 false：关 SQL echo、日志降到 INFO（上面 APP_DEBUG 一处即可）。
LLM_MAX_RETRIES=3          # LLM/embedding 调用重试次数（429/超时自动退避重试）
LLM_TIMEOUT=60             # 单次 LLM 请求超时（秒）
MAX_CONCURRENT_REQUESTS=400  # 同时处理的请求数上限，超过返回 503
DB_POOL_SIZE=20            # DB 连接池常驻数
DB_MAX_OVERFLOW=20         # 池满后可临时多开数
DB_STATEMENT_TIMEOUT_MS=30000  # 单条 SQL 超时（毫秒）
