# ===== 应用 =====
APP_NAME=data-middle-platform
APP_ENV=dev
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# ===== PostgreSQL（RAG 向量库 + 中台元数据）=====
PG_HOST=127.0.0.1
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=changeme
PG_DATABASE=data_platform

# ===== SQL Server（业务数据，只读，TextToSQL 用；P5 启用）=====
# 留空则 TextToSQL 相关功能自动跳过（health/mssql 返回 skipped）。填 HOST + DATABASE 才算启用。
MSSQL_HOST=
MSSQL_PORT=1433
MSSQL_USER=
MSSQL_PASSWORD=
MSSQL_DATABASE=
MSSQL_TIMEOUT=30
# TDS 协议版本：SQL Server 2008/2008R2 用 7.0（新版本与老库 TLS 握手会失败）。
# 2012+ 的库可改 7.3/7.4。详见 app/core/config.py 的说明。
MSSQL_TDS_VERSION=7.0

# ===== 任务队列：procrastinate 复用上面的 PostgreSQL，无需额外配置 =====

# ===== MinIO（上传原件对象存储）=====
MINIO_ENDPOINT=192.168.120.198:9000
MINIO_ACCESS_KEY=KUexgN1kwl7FcfSKZuJG
MINIO_SECRET_KEY=请填入真实密钥
MINIO_BUCKET=temp
MINIO_SECURE=false

# ===== LLM：通义千问（DashScope OpenAI 兼容）=====
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_API_KEY=
QWEN_DEFAULT_MODEL=qwen-plus

# ===== LLM：DeepSeek =====
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_API_KEY=
DEEPSEEK_DEFAULT_MODEL=deepseek-chat

# ===== Embedding（通义 text-embedding-v3）=====
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_DIM=1024

# ===== 重排序 rerank（混合检索后精排，可配开关，默认关）=====
RERANK_ENABLED=false
RERANK_MODEL=gte-rerank-v2

# ===== 上传限制（白名单可配置：逗号分隔扩展名；大小单位 MB）=====
UPLOAD_MAX_MB=100
# 只放能解析出文字的格式；doc/xls 老二进制格式暂不支持解析，故不放
UPLOAD_ALLOWED_EXTS=pdf,docx,xlsx,txt,md
